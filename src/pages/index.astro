---
import Layout from '../components/Layout.astro';
import { readFileSync } from 'fs';
import path from 'path';

const tourDataPath = path.join(process.cwd(), 'src/data/tour-data.json');
let tourData: any = { rides: [], tourName: 'Tour', description: '', startDate: '', endDate: '', totalMiles: '0', totalElevation: 0 };

try {
  tourData = JSON.parse(readFileSync(tourDataPath, 'utf-8'));
} catch (err) {
  console.warn('Could not load tour-data.json');
}

const { tourName, startDate, endDate, description, rides, totalMiles, totalElevation, media } = tourData;
const landingPanda = media?.r2Base ? `${media.r2Base}/BTF_CDM_LANDING_PANDA_v1.png` : null;
const rideCount = rides.filter((r: any) => r.miles > 0 && r.dayNumber !== 'REST').length;
const restCount = rides.filter((r: any) => r.dayNumber === 'REST').length;

function badgeLabel(dayNumber: string) {
  if (dayNumber === 'REST') return 'Rest Day';
  if (dayNumber === '0') return 'Arrival';
  return `Day ${dayNumber}`;
}
function badgeClass(dayNumber: string) {
  if (dayNumber === 'REST') return 'ride-card-badge rest-day';
  if (dayNumber === '0') return 'ride-card-badge arrival';
  return 'ride-card-badge';
}
---

<Layout title={tourName} description={description}>
  <div class="hero">
    <div class="container">
      <p class="hero-eyebrow">BikeTourFrance.net</p>
      <h1>{tourName}</h1>
      <p class="hero-route">Bordeaux → Sète &nbsp;·&nbsp; {startDate} – {endDate}</p>
      {landingPanda && (
        <img src={landingPanda} alt={tourName} class="hero-panda" />
      )}

      <div class="stat-grid">
        <div class="stat-cell">
          <span class="stat-value">{rideCount}</span>
          <span class="stat-label">Ride Days</span>
        </div>
        <div class="stat-cell">
          <span class="stat-value">{restCount}</span>
          <span class="stat-label">Rest Days</span>
        </div>
        <div class="stat-cell">
          <span class="stat-value">{parseFloat(totalMiles).toFixed(0)}</span>
          <span class="stat-label">Miles</span>
        </div>
        <div class="stat-cell">
          <span class="stat-value">{Number(totalElevation).toLocaleString()}</span>
          <span class="stat-label">ft Elevation</span>
        </div>
      </div>
    </div>
  </div>

  <section>
    <div class="container">
      <div class="section-header">
        <h2>The Route</h2>
        <p>{description}</p>
      </div>
      <div class="ride-grid">
        {rides.map((ride: any) => (
          <a href={`/${ride.dayNumber}`} class="ride-card">
            <span class={badgeClass(ride.dayNumber)}>
              {badgeLabel(ride.dayNumber)}
            </span>
            {(ride.startTown || ride.endTown) && (
              <p class="ride-card-route">
                {ride.startTown}
                {ride.startTown && ride.endTown && <span class="ride-card-arrow"> → </span>}
                {ride.endTown}
              </p>
            )}
            {ride.miles > 0 && (
              <div class="ride-card-stats">
                <span>{ride.miles.toFixed(0)} mi</span>
                <span>{ride.elevation.toLocaleString()} ft</span>
              </div>
            )}
            {ride.date && <p class="ride-card-date">{ride.date}</p>}
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
