---
import Layout from '../components/Layout.astro';
import HomepageContent from '../components/HomepageContent.astro';
import { readFileSync } from 'fs';
import path from 'path';

const tourDataPath = path.join(process.cwd(), 'src/data/tour-data.json');
let tourData: any = { rides: [], tourName: 'Tour', description: '', startDate: '', endDate: '', totalMiles: '0', totalElevation: 0 };

try {
  tourData = JSON.parse(readFileSync(tourDataPath, 'utf-8'));
} catch (err) {
  console.warn('Could not load tour-data.json');
}

const { tourName, startDate, endDate, description, rides, endToEndRwgpsId } = tourData;
---

<Layout title={tourName} description={description} fullRouteId={endToEndRwgpsId}>
  <HomepageContent {rides} {tourName} {startDate} {endDate} {description} {endToEndRwgpsId} />
</Layout>
/* Force rebuild */
