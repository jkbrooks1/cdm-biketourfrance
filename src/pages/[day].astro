---
import Layout from "../components/Layout.astro";
import DaySelector from '../components/DaySelector.astro';
import TourDayNav from '../components/TourDayNav.astro';
import TodayBlock from "../components/TodayBlock.astro";
import { readFileSync } from 'fs';
import path from 'path';

export async function getStaticPaths() {
  const tourData = await import("../data/tour-data.json");
  const rides = Array.isArray(tourData?.rides) ? tourData.rides : [];

  const allowedRideTypes = ["arrival", "ride", "rest", "train", "overview"];

  const filteredPages = rides
    .filter((ride) => allowedRideTypes.includes(ride?.rideType))
    .map((ride) => {
      const dayValue = ride?.rideDay ?? ride?.tourDayNum;
      const day = String(dayValue ?? "").trim().toUpperCase();
      return { ride, day };
    })
    .filter(({ day }) =>
      day !== "" &&
      day !== "NULL"
    );

  return filteredPages.map(({ ride, day }, index) => {
    const prevEntry = index > 0 ? filteredPages[index - 1] : null;
    const nextEntry = index < filteredPages.length - 1 ? filteredPages[index + 1] : null;

    return {
      params: { day },
      props: {
        ride: { ...ride, rideDay: day === "REST" ? "REST" : Number(day) },
        prevDay: prevEntry?.day ?? null,
        nextDay: nextEntry?.day ?? null
      }
    };
  });
}

const { ride, prevDay, nextDay } = Astro.props;

// Get full tour data for endToEndRwgpsId
const tourDataPath = path.join(process.cwd(), 'src/data/tour-data.json');
let tourData: any = { endToEndRwgpsId: '' };
try {
  tourData = JSON.parse(readFileSync(tourDataPath, 'utf-8'));
} catch (err) {
  console.warn('Could not load tour-data.json');
}
const endToEndRwgpsId = tourData.endToEndRwgpsId;
---
<Layout fullRouteId={endToEndRwgpsId}>
  {(ride.rideType === 'overview' || ride.rideType === 'arrival' || ride.rideType === 'ride' || ride.rideType === 'rest' || ride.rideType === 'train') && (
    <header class="day-header">
      <div class="day-header-row1">
        <div class="header-logo-space"></div>
        <div class="header-nav-group">
          {prevDay ? (
            <a href={`/${prevDay}`} class="header-nav-arrow" title="Previous day">⬅️</a>
          ) : (
            <span class="header-nav-arrow disabled">⬅️</span>
          )}
          <a href={`/${ride.rideDay}/route`} class="header-nav-control" title="Water & Stops">WC💧🥐</a>
          {nextDay ? (
            <a href={`/${nextDay}`} class="header-nav-arrow" title="Next day">➡️</a>
          ) : (
            <span class="header-nav-arrow disabled">➡️</span>
          )}
        </div>
      </div>
      <div class="day-header-row2">
        <a href={`/${ride.rideDay}/towns`} class="header-control" title="Towns">Towns</a>
        <a href="https://wa.me/message/66EXRA4TTXH7P1" target="_blank" rel="noopener" class="header-control">
          <img src={tourData.media.whatsAppIcon} alt="WhatsApp" class="header-control-icon" />
        </a>
        {tourData.rwgpsCollectionUrl && (
          <a href={`${tourData.rwgpsCollectionUrl}?openExternalBrowser=1`} target="_blank" rel="noopener" class="header-control" title="Open RWGPS collection in web browser">
            <img src="/icons/rwgps-cyclist-only-v2.png" alt="RWGPS collection" class="header-control-icon rwgps-icon" />
          </a>
        )}
        <a href="/" class="header-control" title="Home">Home</a>
      </div>
    </header>
  )}

  <main>
    <div class="day-page-container">
      <div class="day-content">
        <DaySelector days={tourData.rides} />
        {(ride.rideType === 'ride' || ride.rideType === 'rest') && <TodayBlock ride={ride} date={ride.date} />}

        {ride.rideType !== 'ride' && ride.rideType !== 'rest' && (
          <div class="day-block">
            <h1>{ride.rideType === 'train' ? `Train Day: ${ride.startTown} → ${ride.endTown}` : 'Day'} {ride.rideType !== 'train' ? (ride.rideDay ?? ride.tourDayNum) : ''}</h1>
            <p class="day-route">{ride.startTown} → {ride.endTown}</p>
            {ride.pandaImageUrl && (
              <div class="panda-hero">
                <img src={ride.pandaImageUrl} alt={`Panda illustration for Day ${ride.rideDay ?? ride.tourDayNum}`} class="panda-hero-img" />
              </div>
            )}
            {ride.destinationNarrative && (
              <div class="narrative">
                <p>{ride.destinationNarrative}</p>
              </div>
            )}
            {ride.rwgpsUrl && (
              <div class="day-nav">
                <a href={ride.rwgpsUrl} target="_blank" rel="noopener" class="nav-link entire-route-link">
                  Entire Route RWGPS →
                </a>
              </div>
            )}
          </div>
        )}


        {(ride.rideType === 'ride' || ride.rideType === 'rest') && (
          <div class="day-nav">
            <a href={`/${ride.rideDay}/route`} class="nav-link">View Route Details</a>
            <a href={`/${ride.rideDay}/towns`} class="nav-link">View Towns</a>
            <a href="/" class="nav-link back-link">← Back to Home</a>
            {endToEndRwgpsId && (
              <a href={`https://www.rwgps.com/routes/${endToEndRwgpsId}`} target="_blank" rel="noopener" class="nav-link entire-route-link">
                Entire Route RWGPS
              </a>
            )}
          </div>
        )}
      </div>
    </div>
  </main>
</Layout>

<style>
  .day-header {
    background: #2D5016;
    border-bottom: 1px solid #1f3810;
  }

  .day-header-row1 {
    display: flex;
    height: 44px;
    align-items: center;
    padding: 0 12px;
    gap: 8px;
  }

  .header-logo-space {
    flex: 0 0 auto;
    width: 40px;
    height: 44px;
  }

  .header-nav-group {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 44px;
    gap: 8px;
    flex: 0 0 auto;
    white-space: nowrap;
    margin: 0 auto;
  }

  .header-nav-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    font-size: 20px;
    line-height: 1;
    padding: 0;
    margin: 0;
    text-decoration: none;
    background: transparent;
    border: 0;
    color: white;
    cursor: pointer;
    transition: opacity 0.2s;
    flex-shrink: 0;
  }

  .header-nav-arrow:hover {
    opacity: 0.7;
  }

  .header-nav-arrow.disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .header-nav-control {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 8px;
    height: 44px;
    font-size: 0.75rem;
    font-weight: 600;
    line-height: 1.2;
    color: white;
    text-decoration: none;
    background: transparent;
    border: 0;
    cursor: pointer;
    transition: opacity 0.2s;
    flex-shrink: 0;
  }

  .header-nav-control:hover {
    opacity: 0.7;
  }

  .day-header-row2 {
    display: flex;
    height: 44px;
    align-items: center;
    padding: 0 12px;
    gap: 8px;
  }

  .header-control {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 78px;
    height: 44px;
    font-size: 0.75rem;
    font-weight: 600;
    color: white;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.1);
    border: 0;
    border-radius: 3px;
    cursor: pointer;
    transition: background 0.2s;
  }

  .header-control:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  .header-control-icon {
    width: 24px;
    height: 24px;
    object-fit: contain;
  }

  .rwgps-icon {
    transform: scale(1.2);
  }

  .day-page-container {
    min-height: calc(100vh - 88px);
    padding: 0.25rem 0 2rem 0;
  }

  .day-content {
    max-width: 360px;
    margin: 0 auto;
    padding: 0 12px;
  }

  .day-block {
    background: white;
    border-radius: 8px;
    padding: 2rem;
    margin: 2rem 0;
  }

  .day-block h1 {
    font-size: 2rem;
    margin: 0 0 1rem 0;
    color: #2D5016;
  }

  .panda-hero {
    margin: 1rem 0 1.5rem 0;
  }

  .panda-hero-img {
    width: 100%;
    max-height: 320px;
    object-fit: cover;
    border-radius: 8px;
    display: block;
  }

  .day-route {
    font-size: 1.25rem;
    color: #333;
    margin: 0.5rem 0 1.5rem 0;
  }

  .narrative {
    line-height: 1.6;
    color: #444;
  }

  .day-nav {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid #eee;
  }

  .nav-link {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: #2D5016;
    color: white;
    text-decoration: none;
    border-radius: 4px;
    font-weight: 600;
    text-align: center;
    transition: background 0.2s;
  }

  .nav-link:hover {
    background: #1f3b0f;
  }

  .back-link {
    background: #666;
  }

  .back-link:hover {
    background: #444;
  }

  .entire-route-link {
    background: #0066cc;
    font-size: 0.9rem;
  }

  .entire-route-link:hover {
    background: #0052a3;
  }

  .highlights-section {
    background: white;
    border-radius: 8px;
    padding: 2rem;
    margin: 2rem 0;
  }

  .highlights-section h2 {
    font-size: 1.5rem;
    margin: 0 0 1.5rem 0;
    color: #2D5016;
  }

  .highlights-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .highlight-item {
    margin-bottom: 1rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #eee;
  }

  .highlight-item:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .highlight-item strong {
    display: block;
    color: #2D5016;
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }

  .highlight-item p {
    font-size: 0.9rem;
    color: #666;
    margin: 0;
    line-height: 1.5;
  }


.day-nav-inline {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 8px 0 12px;
  font-size: 22px;
}

.day-nav-inline a {
  text-decoration: none;
  padding: 8px 12px;
}
</style>
