---
interface Props {
  ride: any;
  date?: string;
}

const { ride, date } = Astro.props;

// Helper functions
function formatDate(raw: string) {
  if (!raw) return '';
  let month: number, day: number, year: number;
  if (raw.includes('-')) {
    [year, month, day] = raw.split('-').map(Number);
  } else if (raw.includes('/')) {
    const parts = raw.split('/').map(Number);
    month = parts[0]; day = parts[1]; year = 2026;
  } else {
    return raw;
  }
  const d = new Date(year, month - 1, day);
  return d.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
}

function calculateRideTime(miles: number): number {
  // Conservative touring pace: 10 mph
  return miles / 10;
}

function calculateTotalDayTime(miles: number): number {
  // Ride time + 50% for stops, lunch, breaks
  const rideTime = calculateRideTime(miles);
  return rideTime * 1.5;
}

function roundTo30Minutes(hours: number): { hours: number; minutes: number } {
  const totalMinutes = Math.round(hours * 60);
  const roundedMinutes = Math.round(totalMinutes / 30) * 30;
  const hours_part = Math.floor(roundedMinutes / 60);
  const minutes_part = roundedMinutes % 60;
  return { hours: hours_part, minutes: minutes_part };
}

function formatTimeRounded(hours: number): string {
  const rounded = roundTo30Minutes(hours);
  return `${rounded.hours}h${rounded.minutes > 0 ? ` ${rounded.minutes}m` : ''}`;
}

function calculateFinishTime(totalHours: number): string {
  // Assuming 9am start, round to nearest 30 minutes
  const startHour = 9;
  const startMinutes = 0;
  const totalMinutes = startHour * 60 + startMinutes + Math.round(totalHours * 60);
  const roundedTotalMinutes = Math.round(totalMinutes / 30) * 30;
  const finishHour = Math.floor(roundedTotalMinutes / 60) % 24;
  const finishMin = roundedTotalMinutes % 60;
  const period = finishHour >= 12 ? 'pm' : 'am';
  const displayHour = finishHour > 12 ? finishHour - 12 : finishHour === 0 ? 12 : finishHour;
  return `${displayHour}:${finishMin.toString().padStart(2, '0')} ${period}`;
}

function getDayShape(miles: number, elevation: number): { label: string; description: string } {
  const effortRatio = elevation / miles;
  if (effortRatio < 25) {
    return { label: 'Mostly flat', description: 'Easy rolling, good for strong pace' };
  } else if (effortRatio < 45) {
    return { label: 'Rolling hills', description: 'Steady climbing, moderate effort' };
  } else {
    return { label: 'Hilly/climbing', description: 'Sustained elevation, plan for slower pace' };
  }
}

function calculateLunchTime(miles: number): string {
  // Lunch around midday, typically at ~50% of ride distance
  const rideTime = calculateRideTime(miles);
  const lunchHour = Math.floor(9 + (rideTime / 2));
  const lunchMin = Math.round((((9 + rideTime / 2) % 1) * 60));
  const period = lunchHour >= 12 ? 'pm' : 'am';
  const displayHour = lunchHour > 12 ? lunchHour - 12 : lunchHour === 0 ? 12 : lunchHour;
  return `~${displayHour}:${lunchMin.toString().padStart(2, '0')} ${period}`;
}

const rideTime = calculateRideTime(ride.miles);
const totalDayTime = calculateTotalDayTime(ride.miles);
const finishTime = calculateFinishTime(totalDayTime);
const dayShape = getDayShape(ride.miles, ride.elevation);
const lunchTime = calculateLunchTime(ride.miles);

// Get first 2 highlights
const highlights = ride.highlights?.slice(0, 2) || [];
---

<div class="today-block">
  <div class="today-header">
    <h2 class="today-title">Ride Day {ride.tourDayNum}</h2>
    <p class="today-route">{ride.startTown} → {ride.endTown}</p>
    {ride.date && <p class="today-date">{formatDate(ride.date)}</p>}
  </div>

  <div class="today-metrics">
    <div class="metric-pair">
      <span class="metric-label">Distance</span>
      <span class="metric-value">{ride.miles.toFixed(0)} mi</span>
    </div>
    <div class="metric-pair">
      <span class="metric-label">Elevation</span>
      <span class="metric-value">{ride.elevation.toLocaleString()} ft</span>
    </div>
    <div class="metric-pair">
      <span class="metric-label">Estimated Tour Time</span>
      <span class="metric-value">{formatTimeRounded(totalDayTime)}</span>
    </div>
  </div>

  <div class="today-section">
    <h3 class="section-label">Lunch</h3>
    {ride.lunch?.name && ride.lunch.name !== 'PER JOHN' ? (
      <>
        <p class="lunch-location">{ride.lunch.name}</p>
        <p class="lunch-timing">Around {lunchTime}</p>
      </>
    ) : (
      <p class="lunch-tbd">Location to be determined</p>
    )}
  </div>

  {highlights.length > 0 && (
    <div class="today-section">
      <h3 class="section-label">Oh, the places you'll go!</h3>
      <p class="seuss-quote">…And will you succeed?<br/>Yes! You will, indeed!<br/>(98 and 3/4 percent<br/>guaranteed.)</p>
      <ul class="highlights-list">
        {highlights.map((h: any) => (
          <li class="highlight-item">
            <strong>{h.title}</strong>
            <p>{h.description}</p>
          </li>
        ))}
      </ul>
    </div>
  )}

  {ride.overnightNarrative && (
    <div class="today-section">
      <h3 class="section-label">Tonight: {ride.endTown}</h3>
      <p class="overnight-narrative">{ride.overnightNarrative}</p>
    </div>
  )}

  {ride.wcTowns && ride.wcTowns.length > 0 && (
    <div class="today-section">
      <h3 class="section-label">Water & Stops</h3>
      <div class="wc-stops">
        {ride.wcTowns.map((town: any) => (
          <div class="wc-stop-card">
            <div class="wc-field">
              <span class="wc-label">MP</span>
              <span class="wc-value">{town.distanceFromStart}</span>
            </div>
            <div class="wc-field">
              <span class="wc-label">Name</span>
              <span class="wc-value">{town.name}</span>
            </div>
            <div class="wc-field">
              <span class="wc-label">Location</span>
              <span class="wc-value">{town.location || '—'}</span>
            </div>
            <div class="wc-field">
              <span class="wc-label">Type</span>
              <span class="wc-value">{town.facilityType || town.wcType || '—'}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  )}

  {ride.towns && ride.towns.length > 0 && (
    <div class="today-section">
      <h3 class="section-label">Towns On Route</h3>
      <div class="towns-list">
        {ride.towns.map((town: any) => (
          <div class="town-item">
            <div class="town-header">
              <strong>{town.name}</strong>
              <span class="town-mp">{town.distanceFromStart} mi</span>
            </div>
            {town.description && <p class="town-description">{town.description}</p>}
          </div>
        ))}
      </div>
    </div>
  )}
</div>

<style>
  .today-block {
    background: #fff;
    border: 1px solid #eee;
    border-radius: 6px;
    padding: 1.5rem;
    margin: 1.5rem 0;
  }

  .today-header {
    margin-bottom: 1.5rem;
  }

  .today-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 0 0.5rem 0;
    color: #2D5016;
  }

  .today-route {
    font-size: 1.125rem;
    margin: 0.25rem 0;
    color: #333;
  }

  .today-date {
    font-size: 0.875rem;
    color: #666;
    margin: 0.25rem 0 0 0;
  }

  .today-metrics {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1.5rem;
    padding: 1rem;
    background: #f9f7f2;
    border-radius: 4px;
  }

  .metric-pair {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .metric-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: #666;
    word-break: break-word;
  }

  .metric-value {
    font-size: 1.25rem;
    font-weight: 700;
    color: #2D5016;
  }

  .today-section {
    margin-bottom: 1.25rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid #eee;
  }

  .today-section:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .section-label {
    font-size: 1rem;
    font-weight: 700;
    color: #666;
    margin: 0 0 0.5rem 0;
    display: block;
  }

  .seuss-quote {
    font-size: 0.8rem;
    font-style: italic;
    color: #2D5016;
    margin: 0.5rem 0 1rem 0;
    line-height: 1.6;
  }

  .day-shape-label {
    font-size: 1.125rem;
    font-weight: 600;
    color: #333;
    margin: 0 0 0.25rem 0;
  }

  .day-shape-description {
    font-size: 0.9rem;
    color: #666;
    margin: 0;
  }

  .finish-time {
    font-size: 0.95rem;
    color: #333;
    margin: 0;
  }

  .lunch-location {
    font-size: 1rem;
    font-weight: 600;
    color: #333;
    margin: 0 0 0.25rem 0;
  }

  .lunch-timing {
    font-size: 0.875rem;
    color: #666;
    margin: 0;
  }

  .lunch-tbd {
    font-size: 0.95rem;
    color: #999;
    margin: 0;
  }

  .stops-info {
    font-size: 0.95rem;
    color: #333;
    margin: 0;
  }

  .highlights-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .highlight-item {
    margin-bottom: 0.75rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid #f0f0f0;
  }

  .highlight-item:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .highlight-item strong {
    display: block;
    color: #2D5016;
    font-size: 0.95rem;
    margin-bottom: 0.25rem;
  }

  .highlight-item p {
    font-size: 0.875rem;
    color: #666;
    margin: 0;
    line-height: 1.4;
  }

  .overnight-narrative {
    font-size: 0.9rem;
    color: #555;
    line-height: 1.5;
    margin: 0;
  }

  .wc-stops {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .wc-stop-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1rem;
    background: #fafaf8;
    border-left: 3px solid #2D5016;
    border-radius: 3px;
  }

  .wc-field {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    min-width: 0;
  }

  .wc-label {
    font-size: 0.7rem;
    font-weight: 700;
    color: #666;
    letter-spacing: 0.5px;
  }

  .wc-value {
    font-size: 0.9rem;
    color: #333;
    word-break: break-word;
    overflow-wrap: anywhere;
    line-height: 1.4;
  }

  /* Tablet and desktop: table-like layout */
  @media (min-width: 640px) {
    .wc-stops {
      display: grid;
      gap: 0;
    }

    .wc-stop-card {
      display: grid;
      grid-template-columns: 60px 1fr 1fr 120px;
      gap: 0.75rem;
      padding: 0.75rem;
      background: transparent;
      border-left: none;
      border-bottom: 1px solid #eee;
      align-items: start;
    }

    .wc-stop-card:last-child {
      border-bottom: none;
    }

    .wc-field {
      display: contents;
    }

    .wc-label {
      display: none;
    }

    .wc-value {
      font-size: 0.85rem;
    }

    .wc-stop-card .wc-field:first-child .wc-value {
      font-weight: 600;
      color: #2D5016;
      white-space: nowrap;
    }

    .wc-stop-card .wc-field:nth-child(2) .wc-value {
      font-weight: 500;
      color: #333;
    }

    .wc-stop-card .wc-field:nth-child(3) .wc-value {
      color: #666;
      font-weight: 500;
    }

    .wc-stop-card .wc-field:nth-child(4) .wc-value {
      color: #666;
      font-size: 0.8rem;
    }
  }

  .towns-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .town-item {
    background: #fafaf8;
    border-left: 3px solid #2D5016;
    padding: 0.75rem;
    border-radius: 3px;
  }

  .town-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .town-header strong {
    font-size: 0.95rem;
    color: #333;
  }

  .town-mp {
    font-size: 0.85rem;
    color: #666;
    font-weight: 500;
    white-space: nowrap;
  }

  .town-description {
    font-size: 0.85rem;
    color: #666;
    margin: 0;
    line-height: 1.4;
  }

  @media (min-width: 640px) {
    .today-metrics {
      grid-template-columns: 1fr 1fr 1fr 1fr;
    }
  }
</style>
