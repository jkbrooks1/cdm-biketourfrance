---
interface Props {
  rides: any[];
}

const { rides } = Astro.props;

// Filter to only ride days (not arrival, rest, train)
const rideDays = rides.filter((r: any) => r.rideType === 'ride');

function formatDate(raw: string) {
  if (!raw) return '';
  let month: number, day: number, year: number;
  if (raw.includes('-')) {
    [year, month, day] = raw.split('-').map(Number);
  } else if (raw.includes('/')) {
    const parts = raw.split('/').map(Number);
    month = parts[0]; day = parts[1]; year = 2026;
  } else {
    return raw;
  }
  const d = new Date(year, month - 1, day);
  return d.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
}
---

<div class="day-selector-wrapper">
  <div class="day-selector">
    <label for="day-picker">Select a day:</label>
    <div class="day-picker-wrap">
      <select id="day-picker" class="day-picker">
        {rideDays.map((day: any) => (
          <option value={day.dayNumber}>
            {formatDate(day.date)} • {day.startTown} → {day.endTown} • {day.miles.toFixed(0)} mi
          </option>
        ))}
      </select>
    </div>
  </div>
</div>

<script>
  // Initialize day selection from localStorage or default to first ride day
  const dayPicker = document.getElementById('day-picker') as HTMLSelectElement;

  if (dayPicker) {
    const savedDay = localStorage.getItem('selectedRideDay');
    if (savedDay) {
      dayPicker.value = savedDay;
    } else {
      // Default to first ride day
      dayPicker.value = dayPicker.options[0].value;
    }

    // Save selection to localStorage and trigger update
    dayPicker.addEventListener('change', (e) => {
      const target = e.target as HTMLSelectElement;
      localStorage.setItem('selectedRideDay', target.value);
      window.dispatchEvent(new CustomEvent('daySelected', { detail: { dayNumber: target.value } }));
    });
  }
</script>

<style>
  .day-selector-wrapper {
    padding: 0.75rem 0;
    border-bottom: 1px solid #ddd;
  }

  .day-selector {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .day-selector label {
    font-size: 0.8rem;
    font-weight: 600;
    color: #333;
    letter-spacing: 0.4px;
  }

  .day-picker-wrap {
    position: relative;
  }

  .day-picker-wrap::after {
    content: "▾";
    position: absolute;
    right: 10px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: #2D5016;
    font-size: 14px;
    font-weight: 600;
  }

  .day-picker {
    padding: 0.625rem 0.5rem 0.625rem 0.5rem;
    padding-right: 32px;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-size: 0.875rem;
    font-family: Montserrat, Arial, sans-serif;
    cursor: pointer;
    min-height: 44px;
    width: 100%;
    -webkit-appearance: none;
    appearance: none;
    background-color: white;
  }

  .day-picker:focus {
    outline: none;
    border-color: #2D5016;
    box-shadow: 0 0 0 2px rgba(45, 80, 22, 0.2);
  }

  @media (min-width: 640px) {
    .day-selector-wrapper {
      padding: 1rem 0;
    }

    .day-selector label {
      font-size: 0.875rem;
    }

    .day-picker {
      padding: 0.75rem;
      padding-right: 32px;
      font-size: 0.95rem;
    }
  }
</style>
