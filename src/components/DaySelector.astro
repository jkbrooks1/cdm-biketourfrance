---
interface Props {
  days: any[];
}

const { days } = Astro.props;
const isRootPage = Astro.url.pathname === '/' || Astro.url.pathname === '/index.html';

// Filter to only ride days (not arrival, rest, train)
const safeDays = Array.isArray(days) ? days : [];
const rideDays = safeDays
  .filter((r: any) => ['arrival', 'ride', 'rest', 'train'].includes(r.rideType))
  .sort((a: any, b: any) => Number(a.tourDayNum ?? 0) - Number(b.tourDayNum ?? 0));

function routeKey(day: any) {
  return String((day.rideDay ?? day.tourDayNum) ?? '').trim().toUpperCase();
}

function getWeekday(raw: string): string {
  if (!raw) return '';
  let month: number, day: number, year: number;
  if (raw.includes('-')) {
    [year, month, day] = raw.split('-').map(Number);
  } else if (raw.includes('/')) {
    const parts = raw.split('/').map(Number);
    month = parts[0]; day = parts[1]; year = 2026;
  } else {
    return '';
  }
  const d = new Date(year, month - 1, day);
  return d.toLocaleDateString('en-US', { weekday: 'short' }).toUpperCase();
}

function formatRideDay(rideDay: any): string {
  const day = String(rideDay ?? '').trim();
  if (!day || day === 'NULL') return '';
  const num = parseInt(day, 10);
  if (!isNaN(num) && num > 0) {
    return `RD${String(num).padStart(2, '0')}`;
  }
  return String(rideDay ?? '').trim().toUpperCase();
}

function optionLabel(day: any) {
  const weekday = getWeekday(day.date);

  if (day.rideType === 'overview') {
    return `OVERVIEW · ${weekday} · ${day.startTown} → ${day.endTown}`;
  }
  if (day.rideType === 'arrival') {
    return `ARRIVAL · ${weekday} · ${day.endTown}`;
  }
  if (day.rideType === 'rest') {
    return `REST · ${weekday} · ${day.startTown}`;
  }
  if (day.rideType === 'train') {
    return `TRAIN · ${weekday} · ${day.startTown} → ${day.endTown}`;
  }

  // Ride days (rideType === 'ride')
  const rideLabel = formatRideDay(day.rideDay);
  return `${rideLabel} · ${weekday} · ${day.startTown} → ${day.endTown} · ${Math.round(day.miles)} mi`;
}

function formatDate(raw: string) {
  if (!raw) return '';
  let month: number, day: number, year: number;
  if (raw.includes('-')) {
    [year, month, day] = raw.split('-').map(Number);
  } else if (raw.includes('/')) {
    const parts = raw.split('/').map(Number);
    month = parts[0]; day = parts[1]; year = 2026;
  } else {
    return raw;
  }
  const d = new Date(year, month - 1, day);
  return d.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
}
---

<div class="day-selector-wrapper">
  <div class="day-selector">
    <label for="day-picker">Select a day:</label>
    <div class="day-picker-wrap">
      <select id="day-picker" class="day-picker">
        <option value="">Select a ride day...</option>
        {rideDays.map((day: any) => (
          <option value={routeKey(day)}>{optionLabel(day)}</option>
        ))}
      </select>
    </div>
  </div>
</div>

<script define:vars={{ isRootPage }}>
  // Initialize day selection from localStorage or default to placeholder on root
  const dayPicker = document.getElementById('day-picker');

  if (dayPicker) {
    if (isRootPage) {
      // Root page: show placeholder (empty value), ignore localStorage
      dayPicker.value = '';
    } else {
      // Day pages: use localStorage or default to first ride day option
      const savedDay = localStorage.getItem('selectedTourDay');
      if (savedDay) {
        dayPicker.value = savedDay;
      } else {
        // Skip placeholder, select first actual ride day
        dayPicker.value = dayPicker.options[1]?.value || '';
      }
    }

    // Handle selection change: navigate to selected day
    dayPicker.addEventListener('change', (e) => {
      const target = e.target;
      const selectedDay = target.value;
      if (selectedDay) {
        localStorage.setItem('selectedTourDay', selectedDay);
        window.location.href = `/${selectedDay}`;
      }
    });
  }
</script>

<style>
  .day-selector-wrapper {
    padding: 0.5rem 0;
    border-bottom: 1px solid #ddd;
  }

  .day-selector {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .day-selector label {
    font-size: 0.8rem;
    font-weight: 600;
    color: #333;
    letter-spacing: 0.4px;
  }

  .day-picker-wrap {
    position: relative;
  }

  .day-picker-wrap::after {
    content: "▾";
    position: absolute;
    right: 10px;
    top: 50%;
    transform: translateY(-50%);
    pointer-events: none;
    color: #2D5016;
    font-size: 14px;
    font-weight: 600;
  }

  .day-picker {
    padding: 0.625rem 0.5rem 0.625rem 0.5rem;
    padding-right: 32px;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-size: 0.875rem;
    font-family: Montserrat, Arial, sans-serif;
    cursor: pointer;
    min-height: 44px;
    width: 100%;
    -webkit-appearance: none;
    appearance: none;
    background-color: white;
  }

  .day-picker:focus {
    outline: none;
    border-color: #2D5016;
    box-shadow: 0 0 0 2px rgba(45, 80, 22, 0.2);
  }

  @media (min-width: 640px) {
    .day-selector-wrapper {
      padding: 1rem 0;
    }

    .day-selector label {
      font-size: 0.875rem;
    }

    .day-picker {
      padding: 0.75rem;
      padding-right: 32px;
      font-size: 0.95rem;
    }
  }
</style>
