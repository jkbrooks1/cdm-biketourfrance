---
interface Stop {
  name: string;
  location: string;
  type: string;
  town: string;
  rendered: string;
}

interface Props {
  ride: any;
}

const { ride } = Astro.props;

// Use pre-computed routeStops from tour-data.json
const allStops: Stop[] = (ride.routeStops || [])
  .map((stop: any) => ({
    name: stop.name || '',
    location: stop.location || stop.town || '',
    type: stop.type.toUpperCase(),
    town: stop.town || '',
    rendered: stop.renderedTown || stop.town || '',
  }));

const hasStops = allStops.length > 0;
---

{hasStops && (
  <div class="route-stops-grid">
    <h3>Towns & Stops Along Route</h3>
    <table class="stops-table">
      <thead>
        <tr>
          <th class="col-name">Name</th>
          <th class="col-location">Location</th>
          <th class="col-type">Type</th>
        </tr>
      </thead>
      <tbody>
        {allStops.map((stop: any) => (
          <tr>
            <td class="col-name">{stop.name}</td>
            <td class="col-location">{stop.location}</td>
            <td class="col-type">{stop.type}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
)}

<style>
  .route-stops-grid {
    margin: 1.5rem 0;
  }

  .route-stops-grid h3 {
    font-size: 1.1rem;
    font-weight: 600;
    color: #2d5016;
    margin: 0 0 0.75rem 0;
    padding-bottom: 0;
  }

  .stops-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.8rem;
    line-height: 1.2;
  }

  .stops-table thead {
    background-color: transparent;
  }

  .stops-table th {
    padding: 0.25rem 0.4rem;
    text-align: left;
    font-weight: 600;
    color: #2d5016;
    border-bottom: 1px solid #2d5016;
    font-size: 0.8rem;
  }

  .stops-table td {
    padding: 0.25rem 0.4rem;
    border-bottom: 1px solid #e8dcc8;
    color: #333;
  }

  .col-name {
    width: 32%;
    font-weight: 500;
  }

  .col-location {
    width: 60%;
  }

  .col-type {
    width: 8%;
    font-weight: 600;
    color: #2d5016;
    font-size: 0.75rem;
    text-align: center;
  }

  @media (max-width: 768px) {
    .stops-table {
      font-size: 0.75rem;
    }

    .stops-table th {
      padding: 0.2rem 0.3rem;
    }

    .stops-table td {
      padding: 0.2rem 0.3rem;
    }

    .col-name {
      width: 30%;
    }

    .col-location {
      width: 60%;
    }
  }
</style>
